{
  "expo": {
    "name": "SubHook",
    "slug": "subhook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1a2e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vibecmd.subhook",
      "buildNumber": "21",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "SubHook uses your location to show fields on the map and provide directions."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1a2e"
      },
      "package": "com.vibecmd.subhook"
    },
    "runtimeVersion": "1.0.0",
    "extra": {
      "eas": {
        "projectId": "fb7c3352-19e5-4b31-b414-00e56cdcc429"
      }
    },
    "owner": "kcunningham408",
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}
